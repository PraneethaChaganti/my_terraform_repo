pipeline{
  agent any

    stages{
      stage('terraform init'){
        steps {
            sh 'cd /var/jenkins_home/workspace/Jenkins_Github_Pipeline'
            sh 'terraform init'
        }
      }
      stage('terraform plan'){
        steps {
            sh 'terraform plan'
        }
      }
      stage('terraform apply'){
        steps {
            sh 'terraform apply -auto-approve'
            sh 'pwd'
        }
       }
      stage('terraform validate'){
        steps {
            sh 'terraform validate'
        }
       }
      stage('terraform output'){
        steps {
            sh 'terraform output'
        }
       }
    }
}

